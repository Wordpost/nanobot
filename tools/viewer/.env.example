# ─────────────────────────────────────────────────────────
#  Nanobot Forensic Viewer — Configuration
# ─────────────────────────────────────────────────────────
# All values are optional. If NANOBOT_SESSIONS_DIR is not set,
# viewer will auto-detect by walking up the directory tree
# looking for .nanobot/workspace/sessions/

# Absolute path to sessions directory
# NANOBOT_SESSIONS_DIR=/opt/nanobot/.nanobot/workspace/sessions

# Server settings
# NANOBOT_PORT=2003
# NANOBOT_HOST=127.0.0.1

# Docker container name (for log streaming)
# NANOBOT_CONTAINER=nanobot-gateway
